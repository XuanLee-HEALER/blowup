{
  "productName": "blowup",
  "version": "2.1.1",
  "identifier": "io.github.xuanlee-healer.blowup",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../../dist"
  },
  "app": {
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      }
    },
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "url": "index.html",
        "title": "blowup",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "visible": false
      },
      {
        "label": "splashscreen",
        "url": "splash.html",
        "title": "Loading",
        "width": 560,
        "height": 340,
        "center": true,
        "decorations": false,
        "resizable": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis", "msi", "deb", "rpm"],
    "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico",
        "icons/icon.png"
      ],
    "resources": [
      "resources/blowup-mcp",
      "resources/skills/**/*"
    ]
  }
}
